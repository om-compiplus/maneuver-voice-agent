# Copy this file to .env and fill in your keys.
# .env is gitignored — .env.example is safe to commit.

# LiveKit (sign up free at https://livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your-secret-here

# Anthropic — Claude Haiku LLM (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram — STT (sign up free at https://console.deepgram.com)
DEEPGRAM_API_KEY=...

# Cartesia — TTS (sign up free at https://play.cartesia.ai)
CARTESIA_API_KEY=...
